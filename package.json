{
  "name": "metavision",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "tsx scripts/seed-mongo.ts",
    "db:setup": "tsx scripts/seed-mongo.ts",
    "db:seed:prisma": "tsx prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "meta:check": "node --env-file=.env.local scripts/check-meta-config.mjs",
    "ai:dev": "npm run start:dev --prefix ai-for-metavision",
    "ai:install": "npm install --prefix ai-for-metavision",
    "bootstrap": "node scripts/bootstrap.mjs",
    "trends:install-py": "pip install -r scripts/trends/requirements.txt",
    "social:test": "tsx scripts/test-social-signals.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@sentry/nextjs": "^10.60.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "leaflet": "^1.9.4",
    "mongoose": "^9.7.2",
    "next": "16.2.9",
    "node-cron": "^4.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "redis": "^4.7.1",
    "socket.io-client": "^4.8.3",
    "stripe": "^18.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
